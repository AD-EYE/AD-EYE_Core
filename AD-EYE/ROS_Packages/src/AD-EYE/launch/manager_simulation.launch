<!-- -->
<launch>
    <node pkg="tf" type="static_transform_publisher" name="os_sensor_tf" args="0 0 0 0 0 0 velodyne os_sensor 100" />

    <arg name="test_automation" default="false"/>
    <rosparam>
        use_sim_time: true
    </rosparam>
    <group if="$(arg test_automation)">
        <rosparam>
            test_automation: true
        </rosparam>
    </group>
    <node
            type="manager.py"
            pkg="adeye"
            name="manager"
            respawn="false"
            output="screen"
    />
</launch>
